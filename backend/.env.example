# Local development only. In Render, add these under Environment Variables.
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER/DATABASE_NAME?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret_of_at_least_32_characters
PORT=5000
NODE_ENV=development
# Leave empty when frontend and backend are served together.
# For a separate frontend, enter its URL. Multiple URLs can be comma-separated.
CLIENT_ORIGIN=
